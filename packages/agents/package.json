{
  "name": "@agent-marena/agents",
  "version": "0.1.0",
  "description": "Reference AI trading agents for Agent-Marena protocol",
  "type": "module",
  "scripts": {
    "momentum":     "npx tsx --env-file=../../.env --env-file=.env.momentum    src/agents/momentum.ts",
    "meanreversion":"npx tsx --env-file=../../.env --env-file=.env.meanreversion src/agents/meanReversion.ts",
    "claude":       "npx tsx --env-file=../../.env --env-file=.env.claude       src/agents/claude.ts",
    "price-sim":    "npx tsx --env-file=../../.env --env-file=.env              src/priceSimulator.ts",
    "demo-driver":  "npx tsx --env-file=../../.env --env-file=.env              src/demoDriver.ts",
    "build":        "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "thirdweb": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
