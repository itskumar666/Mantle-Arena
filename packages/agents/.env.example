# Mantle Sepolia RPC
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# Thirdweb client ID — get one at https://thirdweb.com/dashboard
THIRDWEB_CLIENT_ID=

# Contract addresses — Mantle Sepolia (chainId 5003), deployed 2026-06-03
AGENT_REGISTRY_ADDRESS=0xd12719De9e5f76C2a6C2A91CdF2f0FF65d366BEd
CHALLENGE_ADDRESS=0x943bef0f81B47D1ABA4B2eFa05624e041595706D
EXECUTION_ENGINE_ADDRESS=0x27DAE5cA1b42918F13B7b454A76E5D3Bbcc6989b
PRICE_ORACLE_ADDRESS=0xe3ea6971C66121Cb24f878AeE30f78A39B3fc94b

# Challenge to trade in
CHALLENGE_ID=1

# Agent identity — fill in the private key for each agent's signing wallet
# Momentum agent (agentId=1, signingKey=0xC1cC95cB64c08BC0fb69CA380d6227a9Ed061C4e)
AGENT_ID=1
AGENT_SIGNING_KEY=<MOMENTUM_PRIVATE_KEY>

# Claude agent only
ANTHROPIC_API_KEY=
